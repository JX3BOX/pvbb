{
    "name": "pvbb",
    "private": true,
    "description": "论坛、QQ机器人、团队等业务项目",
    "scripts": {
        "dev": "vue-cli-service serve --mode development",
        "serve": "vue-cli-service serve --mode production",
        "debug": "vue-cli-service serve --mode debug",
        "build": "npm run build:prod",
        "build:dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vue-cli-service build --mode development",
        "build:prod": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vue-cli-service build --mode production",
        "lint": "vue-cli-service lint",
        "update": "npm --registry https://registry.npmjs.org install @jx3box/jx3box-common@latest @jx3box/jx3box-data@latest @jx3box/jx3box-ui@latest @jx3box/jx3box-editor@latest"
    },
    "browserslist": [
        "Chrome >= 76",
        "Android >= 76",
        "iOS >= 12",
        "Safari >= 12",
        "Firefox >= 78",
        "Edge >= 79"
    ],
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/vue3-essential"
        ],
        "rules": {
            "vue/multi-word-component-names": "off"
        },
        "parserOptions": {
            "parser": "@babel/eslint-parser"
        }
    },
    "dependencies": {
        "@element-plus/icons-vue": "^2.3.2",
        "@imengyu/vue3-context-menu": "^1.5.4",
        "@jx3box/jx3box-common": "^9.2.4",
        "@jx3box/jx3box-data": "^3.9.5",
        "@jx3box/jx3box-editor": "^3.1.5",
        "@jx3box/jx3box-emotion": "^1.2.14",
        "@jx3box/jx3box-facedat": "^2.7.3",
        "@jx3box/jx3box-fe-proxy": "^1.0.1",
        "@jx3box/jx3box-map": "^1.1.1",
        "@jx3box/jx3box-talent": "^1.3.12",
        "@jx3box/jx3box-ui": "^2.2.5",
        "axios": "^1.3.4",
        "core-js": "^3.8.3",
        "dayjs": "^1.11.7",
        "echarts": "^5.6.0",
        "element-china-area-data": "^5.0.2",
        "element-plus": "^2.13.5",
        "html2canvas": "^1.4.1",
        "jquery": "^3.7.1",
        "localforage": "^1.7.3",
        "lodash": "^4.17.21",
        "lottie-web": "^5.12.2",
        "mitt": "^3.0.1",
        "qrcode.vue": "^3.8.1",
        "sterilizer": "^0.1.1",
        "tributejs": "^5.1.3",
        "vue": "^3.5.13",
        "vue-draggable-plus": "^0.6.1",
        "vue-router": "^4.0.16",
        "vue-svg-inline-plugin": "^2.2.3",
        "vue-waterfall-rapid": "^1.0.25",
        "vuedraggable": "^4.1.0",
        "vuex": "^4.1.0",
        "wc-waterfall": "^0.1.3"
    },
    "devDependencies": {
        "@babel/core": "^7.12.16",
        "@babel/eslint-parser": "^7.28.6",
        "@babel/plugin-proposal-optional-chaining": "^7.14.5",
        "@tailwindcss/postcss": "^4.2.1",
        "@vue/cli-plugin-babel": "~5.0.0",
        "@vue/cli-plugin-eslint": "~5.0.0",
        "@vue/cli-service": "~5.0.0",
        "autoprefixer": "^10.4.27",
        "cross-env": "^7.0.3",
        "csslab": "^6.0.5",
        "eslint": "^7.32.0",
        "eslint-plugin-vue": "^8.0.3",
        "glob": "^7.1.6",
        "less": "^4.1.3",
        "less-loader": "^11.0.0",
        "postcss": "^8.5.8",
        "sass": "^1.97.3",
        "sass-loader": "^16.0.7",
        "style-resources-loader": "^1.5.0",
        "tailwindcss": "^4.2.1",
        "vue-svg-inline-loader": "^2.1.3"
    }
}
